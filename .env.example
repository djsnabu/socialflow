# ============================================
# SocialFlow Environment Variables
# Copy to .env and fill in values
# ============================================

# Database
DATABASE_URL=postgresql://socialflow:socialflow@localhost:5432/socialflow

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Better Auth)
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:3001

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# OAuth — X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=

# OAuth — LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# OAuth — Meta (Facebook + Instagram)
META_APP_ID=
META_APP_SECRET=

# Bluesky (AT Protocol)
# Per-user, stored in DB — no global env needed

# Encryption key for tokens stored in DB (32 bytes hex)
TOKEN_ENCRYPTION_KEY=generate-64-char-hex-string-here
