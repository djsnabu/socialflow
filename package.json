{
  "name": "socialflow",
  "private": true,
  "scripts": {
    "dev": "dotenv -- turbo dev",
    "build": "dotenv -- turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "dotenv -- turbo db:generate --filter=@socialflow/db",
    "db:migrate": "dotenv -- turbo db:migrate --filter=@socialflow/db",
    "db:push": "dotenv -- turbo db:push --filter=@socialflow/db",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
